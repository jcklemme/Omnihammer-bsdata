    <profile id="b2e4c6d3-0000-4000-8000-000000000050" name="Collar of Khorne" hidden="false" profileTypeId="a1f3b5c2-0000-4000-8000-000000000014">
      <profiles/>
      <rules/>
      <infoLinks/>
      <modifiers/>
      <characteristics>
        <characteristic name="Description" characteristicTypeId="a1f3b5c2-0000-4000-8000-000000000140" value="Grants the equipped model and their unit the Adamantium Will special rule. May only be taken by models with the Mark of Khorne or Daemon of Khorne special rule."/>
      </characteristics>
    </profile>
    <profile id="b2e4c6d3-0000-4000-8000-000000000051" name="Icon of Chaos" hidden="false" profileTypeId="a1f3b5c2-0000-4000-8000-000000000014">
      <profiles/>
      <rules/>
      <infoLinks/>
      <modifiers/>
      <characteristics>
        <characteristic name="Description" characteristicTypeId="a1f3b5c2-0000-4000-8000-000000000140" value="When determining the assault result, add one to your total if there are one or more friendly units with an Icon of Chaos locked in that combat. Additionally, if the first model from a friendly Deep Striking unit is placed within 6&quot; of a model with an Icon of Chaos, and both units share the same daemonic alignment (both Daemon of Khorne, both Tzeentch, etc.), the Deep Striking unit does not scatter. If they share only the Daemon rule but different alignment, the Deep Striking unit scatters D6&quot; instead of the usual amount."/>
      </characteristics>
    </profile>
    <profile id="b2e4c6d3-0000-4000-8000-000000000052" name="Banner of Blood" hidden="false" profileTypeId="a1f3b5c2-0000-4000-8000-000000000014">
      <profiles/>
      <rules/>
      <infoLinks/>
      <modifiers/>
      <characteristics>
        <characteristic name="Description" characteristicTypeId="a1f3b5c2-0000-4000-8000-000000000140" value="A Banner of Blood IS an Icon of Chaos. Additionally, once per game, the unit bearing the Banner of Blood can charge +D6&quot;. Declare use of the Banner before the charge is declared."/>
      </characteristics>
    </profile>
    <profile id="b2e4c6d3-0000-4000-8000-000000000053" name="Instrument of Chaos" hidden="false" profileTypeId="a1f3b5c2-0000-4000-8000-000000000014">
      <profiles/>
      <rules/>
      <infoLinks/>
      <modifiers/>
      <characteristics>
        <characteristic name="Description" characteristicTypeId="a1f3b5c2-0000-4000-8000-000000000140" value="When a unit with an Instrument of Chaos in Deep Strike reserve successfully passes its Reserve Roll, you may choose another unit entirely composed of Daemon models still in Deep Strike reserve that has yet to roll for Reserves — that unit automatically arrives (no roll is made). Additionally, on certain Warp Storm results (Khorne&apos;s Wrath, Storm of Fire, Rot Glorious Rot, The Dark Prince Thirsts), you may re-roll a single hit/miss dice for each friendly matching-god Daemon unit with an Instrument of Chaos on the table."/>
      </characteristics>
    </profile>
